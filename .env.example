# Agent key
PROVIDER=

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=/api/v1
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000

OPENAI_API_KEY=
OPENAI_API_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=

OPENAI_MODEL_NAME=
ANTHROPIC_MODEL_NAME=
TEMPERATURE=
AGENT_MAX_STEPS=10
CONTEXT_WINDOW_TOKENS=200000
CONTEXT_COMPACTION_TRIGGER_RATIO=0.65
CONTEXT_COMPACTION_TARGET_RATIO=0.45

# Agent DB
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Infrastructure connectors
SSH_ALLOWED_NODES=
SSH_NODE_HOST_MAP=
SSH_KNOWN_HOSTS=
SSH_AUTO_ADD_HOST_KEYS=false
SSH_RESTART_ALLOWED_SERVICES=

# Sandbox (chạy run_skill_script bằng Docker container trên host).
# Không cần API key/KVM/kernel — chỉ cần Docker daemon khả dụng.
# SANDBOX_ENABLED=false để tắt hẳn run_skill_script.
SANDBOX_ENABLED=true
# Image dev có sẵn dependency cho skill kết nối DB/SSH/API.
# Build trước khi chạy skill thật:
#   docker build -t telecom-agent-sandbox:latest -f sandbox.Dockerfile .
SANDBOX_IMAGE=telecom-agent-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY=256m
SANDBOX_CPUS=1.0
# Keep isolated by default. Set to host only for explicitly reviewed runtime skills
# that must reach trusted infrastructure.
SANDBOX_NETWORK=none

# Run lifecycle
RUN_TIMEOUT_SECONDS=3600
RUN_TIMEOUT_SWEEPER_ENABLED=true
RUN_TIMEOUT_SWEEPER_INTERVAL_SECONDS=60
RUN_TIMEOUT_SWEEPER_LIMIT=100

# Workflow and observability
CHECKPOINTER_BACKEND=postgres
CHECKPOINTER_DATABASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=300
OTEL_SERVICE_NAME=telecom-agent-backend
